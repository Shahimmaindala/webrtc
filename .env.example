# Next.js Application Port (default: 3000)
PORT=3000

# Signaling Server Port (default: 3001)
SIGNALING_PORT=3001

# Signaling Server URL (for client-side connections)
# Development: http://localhost:3001
# Production: https://your-domain.com or http://your-ip:3001
NEXT_PUBLIC_SIGNALING_URL=http://localhost:3001

# Allowed CORS Origins (comma-separated for production)
# Example: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/webrtc
